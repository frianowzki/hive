{
  "cleanUrls": true,
  "routes": [
    { "src": "/dashboard", "dest": "/dashboard.html" },
    { "src": "/deployer", "dest": "/sovereign-deployer.html" },
    { "src": "/(.*)", "dest": "/$1" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
