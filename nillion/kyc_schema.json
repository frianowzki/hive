{
  "type": "standard",
  "name": "hive_kyc_collection",
  "schema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "array",
    "uniqueItems": true,
    "items": {
      "type": "object",
      "properties": {
        "_id": {
          "type": "string",
          "format": "uuid"
        },
        "wallet_address": {
          "type": "string"
        },
        "kyc_level": {
          "type": "number"
        },
        "verified_at": {
          "type": "number"
        },
        "full_name": {
          "type": "object",
          "properties": {
            "%share": { "type": "string" }
          },
          "required": ["%share"]
        },
        "date_of_birth": {
          "type": "object",
          "properties": {
            "%share": { "type": "string" }
          },
          "required": ["%share"]
        },
        "country_code": {
          "type": "object",
          "properties": {
            "%share": { "type": "string" }
          },
          "required": ["%share"]
        },
        "document_hash": {
          "type": "object",
          "properties": {
            "%share": { "type": "string" }
          },
          "required": ["%share"]
        }
      },
      "required": ["_id", "wallet_address", "kyc_level", "verified_at", "full_name", "date_of_birth", "country_code", "document_hash"],
      "additionalProperties": false
    }
  }
}
